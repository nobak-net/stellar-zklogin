{
  "name": "@nobak/stellar-zklogin",
  "version": "0.1.0",
  "description": "ZK social login for Stellar/Soroban — client-side proving, on-chain and off-chain verification",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "poseidon-lite": "^0.3.0"
  },
  "peerDependencies": {
    "@stellar/stellar-sdk": ">=12.0.0"
  },
  "peerDependenciesMeta": {
    "@stellar/stellar-sdk": {
      "optional": true
    }
  },
  "optionalDependencies": {
    "snarkjs": "^0.7.0"
  },
  "devDependencies": {
    "@stellar/stellar-sdk": "^12.0.0",
    "snarkjs": "^0.7.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.0.0"
  },
  "keywords": [
    "stellar",
    "soroban",
    "zklogin",
    "zero-knowledge",
    "groth16",
    "social-login",
    "zk-proof"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nobak-net/stellar-zklogin"
  }
}
